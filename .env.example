# ---- Environment Variables ----
# Copy this file as .env for local development:
#   cp .env.example .env
#
# On Railway, set these in the Variables tab instead.

# Leave empty to use SQLite locally (default: sqlite:///tasks.db)
# On Railway, this is auto-set when you add a PostgreSQL plugin.
DATABASE_URL=

# Flask session secret key
SECRET_KEY=change-me-to-something-random
